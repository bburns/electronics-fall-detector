# ── Device ────────────────────────────────────────────────────────────────────
DEVICE_NAME=Grandma

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
CONFIRM_DELAY_MS=30000    # seconds user has to press cancel before alerts fire
REPEAT_ALERT_MS=120000    # re-alert if no response after this many ms
LOG_EVENTS=true

# ── SMS via Twilio ─────────────────────────────────────────────────────────────
# Get free trial at twilio.com — $1 credit covers ~100 SMS
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token
TWILIO_FROM=+15551234567
CAREGIVER_PHONES=+15559876543,+15551112222   # comma-separated

# ── Push via ntfy.sh (free, no account needed) ────────────────────────────────
# Install ntfy app on caregiver phones, subscribe to this topic
# Or self-host: https://docs.ntfy.sh/install/
NTFY_TOPIC=my-family-fall-alerts-abc123     # make this hard to guess
NTFY_SERVER=https://ntfy.sh                 # or your self-hosted URL

# ── Email via SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_app_password                 # Gmail: use App Password, not main password
CAREGIVER_EMAILS=caregiver@example.com,doctor@example.com

# ── Telegram ──────────────────────────────────────────────────────────────────
# 1. Create bot via @BotFather → get token
# 2. Each caregiver messages the bot, get their chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_IDS=123456789,987654321
